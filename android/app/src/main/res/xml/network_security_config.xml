<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Disallow cleartext (HTTP) traffic for all domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Pin certificates for the API domain -->
    <domain-config>
        <domain includeSubdomains="true">api.fishfeed.club</domain>
        <pin-set expiration="2027-01-01">
            <!-- Leaf certificate SPKI pin (updated 2026-04-01) -->
            <pin digest="SHA-256">whqW8lnFKCQeaFc0A1/HY2dYRNSpCii8Xdh2ON3syVc=</pin>
            <!-- Intermediate CA SPKI pin (updated 2026-04-01) -->
            <pin digest="SHA-256">kZwN96eHtZftBWrOZUsd6cA4es80n3NzSk/XtYz2EqQ=</pin>
        </pin-set>
    </domain-config>

    <!-- Allow cleartext for localhost in debug builds (emulator/dev server) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
